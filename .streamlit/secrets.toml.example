# Renomeie este arquivo para secrets.toml e preencha com suas credenciais
# NÃO commite o arquivo secrets.toml no git

[gcp_service_account]
type = "service_account"
project_id = "SEU_PROJECT_ID"
private_key_id = "SEU_PRIVATE_KEY_ID"
private_key = "-----BEGIN RSA PRIVATE KEY-----\nSUA_CHAVE_PRIVADA\n-----END RSA PRIVATE KEY-----\n"
client_email = "seu-email@seu-projeto.iam.gserviceaccount.com"
client_id = "SEU_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"

[sheets]
spreadsheet_id = "ID_DA_SUA_PLANILHA_GOOGLE_SHEETS"
